<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fire Risk Result</title>
    <style>
        body {
            background-color: #121212;
            color: #ff4500;
            font-family: Arial, sans-serif;
            text-align: center;
            padding: 50px;
        }
        .result-container {
            background-color: #1e1e1e;
            padding: 30px;
            border-radius: 10px;
            display: inline-block;
        }
        .high-risk {
            color: #ff0000;
            font-weight: bold;
            font-size: 24px;
        }
        .low-risk {
            color: #00ff00;
            font-weight: bold;
            font-size: 24px;
        }
        a {
            color: #ff4500;
            text-decoration: none;
            font-size: 18px;
        }
        a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="result-container">
        <h1>Forest Fire Risk Assessment</h1>
        <!-- Example: replace {{ risk_level }} with backend variable -->
        <p>Your predicted fire risk level is:</p>
        <p class="{{ risk_class }}">{{ risk_level }}</p>
        <a href="/">Check Another</a>
    </div>
</body>
</html>
